{
  "name": "ghawb",
  "version": "2.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "generate:workflows": "bun run scripts/generate-workflows.ts",
    "verify:docs": "bun run scripts/verify-docs.ts",
    "verify:workflows": "bun run scripts/verify-workflows.ts",
    "verify:pre-push": "bun run scripts/verify-pre-push.ts",
    "test": "bun run test:vitest && bun run test:deno",
    "test:vitest": "vitest run",
    "coverage": "vitest run --coverage",
    "test:deno": "deno test --allow-read=tests/deno/fixtures tests/deno",
    "lint": "oxlint -c oxlint.config.jsonc . --deny-warnings",
    "format": "oxfmt -c oxfmt.config.jsonc .",
    "format:check": "oxfmt -c oxfmt.config.jsonc --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "bun run format && bun run format:check && bun run lint && bun run typecheck && bun run verify:docs && bun run test"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@ghawb/sdk": "^2.0.1",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.11"
}
